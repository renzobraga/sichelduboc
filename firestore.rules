rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "contato@sichelduboc.com.br" ||
         request.auth.token.email == "ia.resguarde@gmail.com");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    match /leads/{leadId} {
      // Leitura e exclusão: APENAS ADMINS (100% Seguro contra vazamento de dados)
      allow read, delete: if isAdmin();
      
      // Criação: Permitida publicamente, mas com VALIDAÇÃO DE DADOS (Evita injeção de lixo)
      allow create: if request.resource.data.keys().hasAll(['nome', 'telefone', 'status'])
                    && request.resource.data.nome is string
                    && request.resource.data.telefone is string
                    && request.resource.data.nome.size() > 0
                    && request.resource.data.nome.size() < 150;
                    
      // Atualização: Permitida apenas para o Webhook mudar o status, ou Admin
      allow update: if isAdmin() || (
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
                    && request.resource.data.status == 'em_atendimento'
      );
    }

    match /messages/{messageId} {
      // Leitura e exclusão: APENAS ADMINS (Ninguém lê as conversas)
      allow read, delete: if isAdmin();
      
      // Criação: Permitida publicamente (para o webhook salvar mensagens), com validação
      allow create: if request.resource.data.keys().hasAll(['leadId', 'text', 'sender'])
                    && request.resource.data.sender in ['user', 'bot']
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() < 5000;
                    
      // Atualização: Apenas Admin
      allow update: if isAdmin();
    }
  }
}
